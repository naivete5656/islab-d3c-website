               /ja/project/buddha-face/contextnet_hu255c0008cb8fe6340d26b769ee3d244e_313842_1200x1200_fit_q75_h2_lanczos_3.webp 1200w&#34;
               src=&#34;/ja/project/buddha-face/contextnet_hu255c0008cb8fe6340d26b769ee3d244e_313842_52143b64e349f18927529a122f35df3e.webp&#34;
               width=&#34;760&#34;
               height=&#34;336&#34;
               loading=&#34;lazy&#34; data-zoomable /&gt;&lt;/div&gt;
  &lt;/div&gt;&lt;/figure&gt;

